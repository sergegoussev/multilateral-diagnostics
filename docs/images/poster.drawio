        <mxCell id="0asuUWs828OCndWCZpTJ-26" parent="0asuUWs828OCndWCZpTJ-25" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Analytical/output diagnostics" vertex="1">
          <mxGeometry height="43.75" width="540" x="60" y="8.75" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-27" parent="0asuUWs828OCndWCZpTJ-25" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="3.3" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="40" y="4.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-28" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="70" width="600" x="40" y="2190" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-29" parent="0asuUWs828OCndWCZpTJ-28" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="When is it enough" vertex="1">
          <mxGeometry height="43.75" width="540" x="60" y="8.75" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-30" parent="0asuUWs828OCndWCZpTJ-28" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="3.4" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="40" y="4.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-31" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="80" width="600" x="1790" y="370" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-32" parent="0asuUWs828OCndWCZpTJ-31" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="What to look out for with multilateral methods?" vertex="1">
          <mxGeometry height="60" width="540" x="60" y="10" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-33" parent="0asuUWs828OCndWCZpTJ-31" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="2" vertex="1">
          <mxGeometry height="80" width="80" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-47" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="70" width="600" x="940" y="2650" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-48" parent="0asuUWs828OCndWCZpTJ-47" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Input diagnostics" vertex="1">
          <mxGeometry height="43.75" width="540" x="60" y="8.75" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-49" parent="0asuUWs828OCndWCZpTJ-47" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="5.2" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="40" y="4.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-50" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="100" width="600" x="2045" y="2660" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-51" parent="0asuUWs828OCndWCZpTJ-50" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Analytical/output diagnostics" vertex="1">
          <mxGeometry height="43.75" width="540" x="60" y="8.75" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-52" parent="0asuUWs828OCndWCZpTJ-50" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="5.3" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="40" y="4.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-53" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="&lt;ul&gt;&lt;li&gt;Multilateral methods take as input a large number of records and involve a lot of calculation. Notably:&lt;/li&gt;&lt;ul&gt;&lt;li&gt;GEKS family - multilayered bilaterals&lt;/li&gt;&lt;li&gt;TPD and TDH - large scale regression (typically with sparse matrices)&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;b&gt;Hard to analyze&lt;/b&gt; - Unlike traditional (bilateral) methods, not intuitive to understand and explain the drivers of price change&lt;/li&gt;&lt;li&gt;&lt;b&gt;Opaqueness introduces risk&amp;nbsp;&lt;/b&gt;- lack of understanding also implies it is hard to detect issues&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;NSOs must validate that everything operates effectively &amp;amp; be able to undersand (and explain) movements.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Goal of the project&lt;/b&gt;: Define and demonstrate representative analytical outputs and supporting diagnostics with open data to (1) lead to a concensus and (2) simplify adoption&lt;/div&gt;" vertex="1">
          <mxGeometry height="420" width="1530" x="70" y="450" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="Potential issues to look out for depend on the class of multilateral:&lt;div&gt;&lt;ul&gt;&lt;li&gt;TDH - estimated using product characteristics&amp;nbsp;&lt;/li&gt;&lt;li&gt;TPD/GEKS - uses appropriate product id (i.e. homogeneous product)&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Characteristics or products thus need to be consistently defined for the length of the window.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Main risk: if coding of (1) characteristics or (2) product ids change within the window -&amp;gt; an incorrect movement will occur.&lt;/div&gt;" vertex="1">
          <mxGeometry height="360" width="840" x="1820" y="470" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-58" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="70" width="600" x="40" y="970" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-59" parent="0asuUWs828OCndWCZpTJ-58" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Monitoring/validation" vertex="1">
          <mxGeometry height="43.75" width="540" x="60" y="8.75" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-60" parent="0asuUWs828OCndWCZpTJ-58" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="3.1" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="40" y="4.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="&lt;b&gt;Goal&lt;/b&gt;: Check that the data was received and is reasonable&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Examples:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Revenue by store / retailer&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Number of unique products (or row)&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Average unit value per unique product code&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Quantities and prices aligned to historic trends&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="820" x="80" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-62" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="&lt;div&gt;&lt;b&gt;Goal&lt;/b&gt;: Check that the data is structured approporiately for input to multilateral indices, and errors have been followed up.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Specifically:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Churn in unique products (could be due to data issues, misclassification, or other coding/processing issues).&lt;/li&gt;&lt;li&gt;Missingness in product characteristics&lt;/li&gt;&lt;li&gt;Unit prices and quanitities lie within historic averages&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="320" width="800" x="80" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-63" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="&lt;b&gt;Goal&lt;/b&gt;: Understand the quality adjusted price change &amp;amp; pick up on issues (whether with the data or the estimation process).&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Example analytical outputs:&lt;br&gt;&lt;ul&gt;&lt;li&gt;Decompose into &#39;point effects&#39;&lt;/li&gt;&lt;li&gt;Combine with other characteristics (brand, type of produce, etc)&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Example output diagnostics:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Validating products that contribute over an expected threshold.&amp;nbsp;&lt;/li&gt;&lt;li&gt;Compare movement for previous periods between this run and previous runs&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="800" x="80" y="1764" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-65" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="Current empirical example focuses on Dominick&#39;s dataset and GEKS calculation.&amp;nbsp;&lt;br&gt;&lt;br&gt;Next steps:&lt;br&gt;&lt;ul&gt;&lt;li&gt;Expand to TPD and TDH methods&lt;/li&gt;&lt;li&gt;Expand to additional open datasets&lt;/li&gt;&lt;li&gt;Validate that dashboards generalize all use cases&lt;/li&gt;&lt;li&gt;Standardize code into a package (if of value)&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="290" width="810" x="1770" y="3520" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-67" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="Example data flow:&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Step 1: Raw (weekly) data files are received.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Step 2: Raw data files are loaded into internal data store that supports simpler analytics.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Both will power monitoring and validation diagnostics.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="580" x="950" y="2344" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-71" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Monitoring/validation" vertex="1">
          <mxGeometry height="43.75" width="540" x="100" y="2654.375" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-72" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=26;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="5.1" vertex="1">
          <mxGeometry height="52.5" width="52.5" x="80" y="2650" as="geometry" />
        </mxCell>
        <mxCell id="Lz9mEM7FwzNVVMmmPr_B-3" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="210" width="210" x="2360" y="60" as="geometry" />
        </mxCell>
        <mxCell id="Lz9mEM7FwzNVVMmmPr_B-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;fontFamily=Helvetica;" value="&lt;i&gt;Checkout the&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;project&amp;nbsp;&lt;/i&gt;&lt;i style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;site&lt;br&gt;(examples, paper, code, and more!)&lt;/i&gt;" vertex="1">
          <mxGeometry height="50" width="410" x="2260" y="280" as="geometry" />
        </mxCell>
        <mxCell id="0asuUWs828OCndWCZpTJ-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="It is important to note that an 80-20 rule is probably feasible. Not all possible scenarios can be forecasted, but common dashboards should answer most questions (or altert for further investigation).&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Structured (and well documented) data pipeline key to support analysts to investigate further as needed.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="810" x="80" y="2270" as="geometry" />
        </mxCell>
        <mxCell id="Lz9mEM7FwzNVVMmmPr_B-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="&lt;ul&gt;&lt;li&gt;Step 3: Classification, outlier detection and aggregation by homogenous products (i.e. aggregation across time, geography, and products) is carried out.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Output data supports main input diagnostics&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="580" x="1560" y="2344" as="geometry" />
        </mxCell>
        <mxCell id="Lz9mEM7FwzNVVMmmPr_B-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=26;" value="&lt;ul&gt;&lt;li&gt;Step 4: Price Index calculation and output of contributions&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Output data supports both analytics and output diagnostics&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="580" x="2130" y="2340" as="geometry" />
        </mxCell>
        <mxCell id="5c0gJmLsoUkNVGH3WJje-4" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;shadow=1;rounded=0;strokeWidth=1;imageBorder=default;imageBackground=none;perimeterSpacing=0;" value="" vertex="1">
          <mxGeometry height="560" width="784" x="91" y="3140" as="geometry" />
        </mxCell>
        <mxCell id="5c0gJmLsoUkNVGH3WJje-6" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;shadow=1;rounded=0;strokeWidth=1;imageBorder=default;" value="" vertex="1">
          <mxGeometry height="280" width="793.72" x="80" y="2770" as="geometry" />
        </mxCell>
        <mxCell id="5c0gJmLsoUkNVGH3WJje-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="Example weekly summary&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="580" x="80" y="2702.5" as="geometry" />
        </mxCell>
        <mxCell id="5c0gJmLsoUkNVGH3WJje-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=26;" value="Example statistics per week" vertex="1">
          <mxGeometry height="60" width="580" x="80" y="3070" as="geometry" />
        </mxCell>
      </root>
